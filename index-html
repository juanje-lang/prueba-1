    <script>
        // Inicializar iconos
        lucide.createIcons();

        // Gestión de envío y eventos de rastreo
        const leadForm = document.getElementById('leadForm');
        const submitBtn = document.getElementById('submitBtn');

        leadForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const originalText = submitBtn.innerText;
            submitBtn.innerText = "PROCESANDO ANÁLISIS 360°...";
            submitBtn.disabled = true;

            try {
                const response = await fetch(leadForm.action, {
                    method: 'POST',
                    body: new FormData(leadForm),
                    headers: { 'Accept': 'application/json' }
                });

                if (response.ok) {
                    // DISPARAR EVENTO LEAD PARA META (PIXEL)
                    if (typeof fbq !== 'undefined') {
                        fbq('track', 'Lead');
                    }
                    
                    // DISPARAR EVENTO LEAD PARA GOOGLE
                    if (typeof gtag !== 'undefined') {
                        gtag('event', 'generate_lead', {
                            'event_category': 'conversion',
                            'event_label': 'Auditoria 360'
                        });
                    }

                    alert('¡Sistemas sincronizados! Tu solicitud ha sido recibida con éxito. Juanje analizará tu caso en las próximas horas.');
                    leadForm.reset();
                } else {
                    alert('Error en la transmisión. Por favor, inténtalo de nuevo.');
                }
            } catch (error) {
                alert('Fallo de conexión. Por favor, revisa tu red.');
            } finally {
                submitBtn.innerText = originalText;
                submitBtn.disabled = false;
            }
        });
    </script>
